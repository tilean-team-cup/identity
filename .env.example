# Copiare in .env e compilare prima di avviare — NON committare .env su git

# PostgreSQL
POSTGRES_PASSWORD=cambia_questa_password_sicura

# Keycloak admin (usato solo al primo bootstrap)
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=cambia_questa_password_sicura

# URL pubblico del bridge
BRIDGE_URL=https://naf-bridge.tilea.net

# NAF OAuth2 — forniti dall'admin NAF
NAF_CLIENT_ID=il_tuo_client_id
NAF_CLIENT_SECRET=il_tuo_client_secret
NAF_REDIRECT_URI=https://forum.tilea.net/auth/oauth2_basic/callback

# Cloudflare Tunnel — copiare il token da Cloudflare Zero Trust → Tunnels → il tuo tunnel → Configure → Install connector
CLOUDFLARE_TUNNEL_TOKEN=il_tuo_token_tunnel

# Chiave RSA per la firma dei JWT OIDC del bridge
# Generare con: node -e "const {generateKeyPairSync}=require('crypto');const {privateKey,publicKey}=generateKeyPairSync('rsa',{modulusLength:2048});console.log('BRIDGE_PRIVATE_KEY='+JSON.stringify(privateKey.export({type:'pkcs8',format:'pem'})));console.log('BRIDGE_PUBLIC_KEY='+JSON.stringify(publicKey.export({type:'spki',format:'pem'})));"
BRIDGE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
BRIDGE_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----\n"

# Secret del client Keycloak per il bridge
# Generare dalla UI Keycloak dopo il primo avvio (passo 4 del piano)
KC_BRIDGE_CLIENT_SECRET=da_generare_dopo
